<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFB7CE"
    android:padding="20dp">

    <TextView
        android:id="@+id/headerTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AV Player Pro"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#880E4F"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/displayCard"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_below="@id/headerTitle"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="15dp"
        app:cardBackgroundColor="#000000">

        <VideoView
            android:id="@+id/mediaDisplay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/displayCard"
        android:layout_marginTop="25dp"
        android:orientation="vertical">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <Button android:id="@+id/btnOpenFile" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:text="OPEN FILE" android:layout_margin="5dp" android:backgroundTint="#880E4F" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnOpenURL" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:text="OPEN URL" android:layout_margin="5dp" android:backgroundTint="#880E4F" android:textColor="#FFFFFF"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <Button android:id="@+id/btnPlay" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:text="PLAY" android:layout_margin="5dp" android:backgroundTint="#D90166" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnPause" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:text="PAUSE" android:layout_margin="5dp" android:backgroundTint="#D90166" android:textColor="#FFFFFF"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <Button android:id="@+id/btnStop" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:text="STOP" android:layout_margin="5dp" android:backgroundTint="#D90166" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnRestart" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:text="RESTART" android:layout_margin="5dp" android:backgroundTint="#D90166" android:textColor="#FFFFFF"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>